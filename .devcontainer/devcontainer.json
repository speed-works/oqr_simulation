{
    "name": "Universal Data Science Lab",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-python.vscode-pylance",
                "njpwerner.autodocstring" // 開発効率UP用
            ]
        }
    },
    // 環境が変わっても権限トラブルを防ぐ
    "remoteUser": "vscode",
    "features": {
        // 必要に応じてGitなどのツールを自動追加
        "ghcr.io/devcontainers/features/common-utils:2": {
            "configureZshAsDefaultShell": true
        }
    }
}